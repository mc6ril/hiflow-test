#!/usr/bin/env sh
set -e

cmd="$1"

if [ -z "$cmd" ]; then
  echo "Usage: ./run <command>"
  echo ""
  echo "Commands:"
  echo "  start       Start Expo dev server"
  echo "  ios         Start on iOS simulator"
  echo "  android     Start on Android emulator/device"
  echo "  web         Start on web"
  echo "  test        Run tests once"
  echo "  test:watch  Run tests in watch mode"
  echo "  lint        Run ESLint"
  echo "  lint:fix    Auto-fix ESLint issues"
  echo "  typecheck   Run TypeScript checks"
  echo "  check       Run lint + typecheck + test"
  echo "  format      Run Prettier write"
  echo "  format:check Run Prettier check"
  exit 1
fi

case "$cmd" in
  start|ios|android|web|test|test:watch|lint|lint:fix|typecheck|check|format|format:check)
    npm run "$cmd"
    ;;
  *)
    echo "Unknown command: $cmd"
    echo "Run './run' to see available commands."
    exit 1
    ;;
esac
